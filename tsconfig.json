{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "moduleResolution": "bundler",
    "isolatedModules": true,
    "skipLibCheck": true,

    "allowJs": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "allowImportingTsExtensions": true
  }
}
